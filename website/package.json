{
  "name": "data-napkin-math-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npm run verify:citations -- --strict && npm run content:check",
    "prebuild:stable": "npm run verify:citations -- --strict && npm run content:check",
    "prebuild:dev": "npm run verify:citations -- --strict && npm run content:check",
    "build": "astro build",
    "build:stable": "SITE_URL=https://exploringai.org PUBLIC_ALLOW_INDEXING=true astro build",
    "build:dev": "PUBLIC_ALLOW_INDEXING=false astro build",
    "verify:citations": "node ../scripts/check-input-citations.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "content:check": "node ./scripts/content-check.mjs",
    "new:input": "node ./scripts/new-content.mjs input",
    "new:scenario": "node ./scripts/new-content.mjs scenario",
    "cf:dev": "wrangler pages dev dist",
    "cf:deploy": "wrangler pages deploy dist"
  },
  "dependencies": {
    "@astrojs/vue": "^5.1.3",
    "astro": "^5.16.6",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "wrangler": "^4.72.0"
  }
}
