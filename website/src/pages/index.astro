---
import NapkinApp from '../components/NapkinApp.vue';
import Layout from '../layouts/Layout.astro';
import { loadNapkinData } from '../lib/napkin-data';

const { inputs, scenarios } = await loadNapkinData();
---

<Layout
  title="Calculator - Exploring AI: Data Napkin Math"
  description="Estimate AI payouts, dataset costs, and benchmark expenses with editable, source-backed inputs."
>
  <NapkinApp
    client:load
    initialInputs={inputs}
    initialScenarios={scenarios}
    showInputLibrary={false}
    pageTitle="Data Napkin Math"
    pageDescription="Editable scenarios for asking what AI revenue, copied libraries, data deals, and training-data mixes might cost, fund, or imply."
  />
</Layout>
