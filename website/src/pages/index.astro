---
import { getCollection } from 'astro:content';
import NapkinApp from '../components/NapkinApp.vue';
import Layout from '../layouts/Layout.astro';
import type { Input, Scenario } from '../lib/calculations';
import { createCalculationFunction, formatValue, humanReadable } from '../lib/calculations';
import { extractInputTokens } from '../lib/formulas.js';
import { INPUT_FOCUS_GROUPS, getInputFocusGroupKey } from '../lib/input-groups';

function getEntryStem(entryId: string) {
  const segments = entryId.split('/').filter(Boolean);
  return segments[segments.length - 1] || entryId;
}

const inputEntries = await getCollection('inputs');
const scenarioEntries = await getCollection('scenarios');
const blogEntries = await getCollection('blogs');
const keyPaperEntries = await getCollection('keyPapers');
const askEntries = await getCollection('asks');

const BLOG_STATUS_LABELS = {
  draft: 'Draft',
  in_progress: 'Essay in progress',
  published: 'Published',
} as const;

const KEY_PAPER_KIND_LABELS = {
  position: 'Position',
  policy: 'Policy',
  empirical: 'Empirical',
  legal: 'Legal',
  tracker: 'Tracker',
} as const;

function sortByOrder<T extends { data: { sort_order?: number | null; title: string } }>(entries: T[]) {
  return [...entries].sort((left, right) => {
    const orderDelta = (left.data.sort_order ?? Number.MAX_SAFE_INTEGER) - (right.data.sort_order ?? Number.MAX_SAFE_INTEGER);
    if (orderDelta !== 0) return orderDelta;
    return left.data.title.localeCompare(right.data.title);
  });
}

const scenarioReferences = scenarioEntries.map((entry) => ({
  id: getEntryStem(entry.id),
  title: entry.data.title,
  category: entry.data.category,
  inputVariables: entry.data.input_variables?.length ? entry.data.input_variables : extractInputTokens(entry.data.formula),
}));

const inputUsage = new Map<string, { id: string; title: string; category: string }[]>();
for (const scenario of scenarioReferences) {
  scenario.inputVariables.forEach((inputKey) => {
    const existing = inputUsage.get(inputKey) ?? [];
    existing.push({
      id: scenario.id,
      title: scenario.title,
      category: scenario.category,
    });
    inputUsage.set(inputKey, existing);
  });
}

const inputs: Record<string, Input> = {};
for (const entry of inputEntries) {
  const { data } = entry;
  const variableName = data.variable_name ?? getEntryStem(entry.id);

  if (inputs[variableName]) {
    throw new Error(`Duplicate input id "${variableName}" found while building the input library.`);
  }

  inputs[variableName] = {
    id: entry.id,
    title: data.title,
    value: data.value,
    default_value: data.value,
    scale: data.scale || 1,
    display_units: data.display_units,
    variable_name: variableName,
    variable_type: data.variable_type,
    entity: data.entity ?? undefined,
    units: data.units,
    source_url: data.source_url ?? undefined,
    nice_name: data.title,
    summary: data.summary ?? undefined,
    importanceRank: data.importanceRank ?? undefined,
    importanceReason: data.importanceReason ?? undefined,
    sourceName: data.sourceName ?? undefined,
    sourceNote: data.sourceNote ?? undefined,
    sourceQuality: data.sourceQuality ?? undefined,
    confidence: data.confidence ?? undefined,
    lastReviewed: data.lastReviewed ?? undefined,
    featured: data.featured ?? false,
    min: data.min ?? undefined,
    max: data.max ?? undefined,
    step: data.step ?? undefined,
    comparisonImage: data.comparisonImage
      ? {
          src: data.comparisonImage.src,
          alt: data.comparisonImage.alt,
          caption: data.comparisonImage.caption ?? undefined,
          href: data.comparisonImage.href ?? undefined,
          label: data.comparisonImage.label ?? undefined,
        }
      : undefined,
    referenceCharts: data.referenceCharts?.map((chart) => ({
      title: chart.title,
      description: chart.description ?? undefined,
      scale: chart.scale ?? undefined,
      bars: chart.bars.map((bar) => ({
        label: bar.label,
        value: bar.value,
        displayValue: bar.displayValue ?? undefined,
        note: bar.note ?? undefined,
        highlight: bar.highlight ?? false,
      })),
    })),
    usedIn: inputUsage.get(variableName) ?? [],
  };
}

const scenarios: Scenario[] = scenarioEntries.map((entry) => {
  const { data } = entry;
  const inputVariables = data.input_variables?.length ? data.input_variables : extractInputTokens(data.formula);

  return {
    id: getEntryStem(entry.id),
    title: data.title,
    description: data.description,
    input_variables: inputVariables,
    inputs: inputVariables,
    formula: data.formula,
    result_label: data.result_label,
    result_units: data.result_units,
    category: data.category,
    result: {
      value: 'Loading...',
      rawValue: null,
      units: data.result_units,
    },
    showExplore: false,
    showCalcDetails: false,
  };
});

function getDecimalPlaces(step?: number) {
  if (!step || step >= 1) return 0;
  const decimalPart = String(step).split('.')[1] ?? '';
  return Math.min(decimalPart.length, 6);
}

function formatInputNumber(input: Input) {
  const displayedValue = formatValue(input.value, input.scale);
  const formatter = new Intl.NumberFormat('en-US', {
    minimumFractionDigits: 0,
    maximumFractionDigits: getDecimalPlaces(input.step),
  });

  return formatter.format(displayedValue);
}

const landingInputIds = [
  'yearly_revenue__openai__dollars',
  'deal_value__reddit_google__dollars',
  'dataset_size__llama3__tokens',
  'dataset_size__olmo3__tokens',
  'training_detail__openai__words_per_token',
  'dataset_size__hle__questions',
  'deal_group_size__reddit__daily_active_users',
  'group_size__world__people',
  'post_training_size__tulu_3__sft_examples',
  'pretraining_composition__dolma_v1_6__web_percent',
];

const landingInputs = landingInputIds
  .map((id) => inputs[id])
  .filter(Boolean)
  .map((input) => ({
    ...input,
    displayValue: formatInputNumber(input),
  }));

const landingInputGroups = INPUT_FOCUS_GROUPS.map((group) => ({
  ...group,
  inputs: landingInputs.filter((input) => getInputFocusGroupKey(input) === group.key),
})).filter((group) => group.inputs.length);

function formatMultiple(value?: number | null) {
  if (value === null || value === undefined || !Number.isFinite(value)) return null;
  if (value >= 100) return `${Math.round(value).toLocaleString('en-US')}x`;
  if (value >= 10) return `${value.toFixed(1)}x`;
  return `${value.toFixed(2)}x`;
}

const commissioningScenario = scenarios.find((scenario) => scenario.id === 'commissioning-new-datasets');
const commissioningScenarioRawValue = commissioningScenario
  ? createCalculationFunction(commissioningScenario)(
      ...commissioningScenario.input_variables.map((inputKey) => inputs[inputKey]?.value ?? 0)
    )
  : null;

const openAiRevenue = inputs['yearly_revenue__openai__dollars']?.value;
const anthropicRevenue = inputs['yearly_revenue__anthropic__dollars']?.value;
const combinedAiRevenue =
  [openAiRevenue, anthropicRevenue]
    .filter((value): value is number => typeof value === 'number' && Number.isFinite(value))
    .reduce((sum, value) => sum + value, 0) || null;

const blogPlaceholder = {
  commissioningCost:
    commissioningScenarioRawValue !== null
      ? `${humanReadable(commissioningScenarioRawValue)} ${commissioningScenario?.result_units ?? ''}`.trim()
      : 'Unavailable',
  openAiRevenue:
    openAiRevenue !== undefined
      ? `${humanReadable(openAiRevenue)} ${inputs['yearly_revenue__openai__dollars']?.units ?? ''}`.trim()
      : 'Unavailable',
  anthropicRevenue:
    anthropicRevenue !== undefined
      ? `${humanReadable(anthropicRevenue)} ${inputs['yearly_revenue__anthropic__dollars']?.units ?? ''}`.trim()
      : 'Unavailable',
  combinedRevenue:
    combinedAiRevenue !== null
      ? `${humanReadable(combinedAiRevenue)} dollars`
      : 'Unavailable',
  multipleVsCombined:
    commissioningScenarioRawValue !== null && combinedAiRevenue !== null
      ? formatMultiple(commissioningScenarioRawValue / combinedAiRevenue)
      : null,
};

const featuredBlogEntry = sortByOrder(
  blogEntries.filter((entry) => (entry.data.visibility ?? 'public') === 'public')
)[0];

const featuredBlog = featuredBlogEntry
  ? {
      title: featuredBlogEntry.data.title,
      excerpt: featuredBlogEntry.data.excerpt,
      statusLabel: BLOG_STATUS_LABELS[featuredBlogEntry.data.status],
    }
  : {
      title: 'Commissioning a new frontier dataset versus current AI revenue',
      excerpt:
        'A working note on the tension between replacement-cost estimates for commissioned training data and the current revenue anchors for frontier AI companies.',
      statusLabel: BLOG_STATUS_LABELS.in_progress,
    };

const curatedPaperHighlights = sortByOrder(
  keyPaperEntries.filter((entry) => (entry.data.visibility ?? 'public') === 'public')
).map((entry) => ({
  title: entry.data.title,
  anchor: entry.data.anchor,
  blurb: entry.data.relevance,
  quality: KEY_PAPER_KIND_LABELS[entry.data.kind],
  links: [
    ...(entry.data.source_url
      ? [
          {
            href: entry.data.source_url,
            label: 'Read source',
          },
        ]
      : []),
    ...((entry.data.links ?? []).map((link) => ({
      href: link.href,
      label: link.label,
    }))),
  ],
}));

const paperHighlightIds = [
  'dataset_size__hle__questions',
  'pretraining_composition__dolma_v1_6__academic_percent',
  'post_training_size__tulu_3__sft_examples',
  'dataset_size__llama3__tokens',
];

const paperHighlights = paperHighlightIds
  .map((id) => inputs[id])
  .filter(Boolean)
  .map((input) => ({
    title: input.sourceName || input.title,
    blurb: input.sourceNote || input.summary || input.importanceReason || 'Reference source highlighted in the input library.',
    anchor: input.title,
    quality: input.sourceQuality,
    links: input.source_url
      ? [
          {
            href: input.source_url,
            label: 'Read source',
          },
        ]
      : [],
  }));

const allPaperHighlights = [...curatedPaperHighlights, ...paperHighlights];

const watchIndicators = [
  'AI company earnings calls, SEC filings, and updated revenue run rates.',
  'Publisher and platform licensing deals, especially renewals with disclosed terms.',
  'Open-model releases that publish training mix, corpus size, or post-training composition.',
  'Benchmark growth and contributor-compensation norms for expert evaluation work.',
  'Inference price movement across flagship and mini model tiers.',
];

const ourAsks = sortByOrder(
  askEntries.filter((entry) => (entry.data.visibility ?? 'public') === 'public')
).map((entry) => entry.data.summary || entry.data.title);
---

<Layout title="Exploring AI: Data Napkin Math">
  <main class="home-shell">
    <section class="landing-hero">
      <div class="hero-copy">
        <p class="section-kicker">Interactive calculator</p>
        <h1>Exploring AI: Data Napkin Math</h1>
        <p class="hero-text">
          Interactive napkin math, back-of-the-envelope estimates, and ballpark figures for training-data
          value, compensation, and distribution questions. How will the proceeds and benefits of AI be
          distributed?
        </p>
        <div class="hero-actions">
          <a class="hero-link hero-link-primary" href="/#calculations">Open calculator</a>
          <a class="hero-link" href="/#inputs">Browse inputs</a>
          <a class="hero-link" href="https://github.com/nickmvincent/exploringai" target="_blank" rel="noreferrer">
            GitHub repository
          </a>
        </div>
      </div>

    </section>

    <section id="inputs" class="landing-section section-inputs">
      <div class="section-header">
        <p class="section-kicker">Section 1</p>
        <h2>Inputs</h2>
        <p>
          Start with plain numbers from public sources, grouped by the kind of question you want to ask.
          Jump straight to money, training scale, people, or data mix instead of scanning one long list.
        </p>
      </div>

      <div class="input-topic-nav" aria-label="Input categories">
        {landingInputGroups.map((group) => (
          <a class="input-topic-link" href={`#input-topic-${group.key}`}>
            {group.prompt}
          </a>
        ))}
      </div>

      <div class="input-topic-list">
        {landingInputGroups.map((group) => (
          <section class="input-topic-section" id={`input-topic-${group.key}`}>
            <div class="input-topic-header">
              <div>
                <p class="section-kicker input-topic-kicker">{group.prompt}</p>
                <h3>{group.label}</h3>
              </div>
              <p>{group.description}</p>
            </div>

            <div class="number-grid">
              {group.inputs.map((input) => (
                <article class="number-card">
                  <div class="number-card-top">
                    <span class="mini-badge">{input.sourceQuality === 'primary' ? 'Primary' : 'Official'}</span>
                    {input.lastReviewed && <span class="number-meta">Reviewed {input.lastReviewed}</span>}
                  </div>
                  <h3>{input.title}</h3>
                  <div class="number-value">{input.displayValue}</div>
                  <div class="number-units">{input.display_units}</div>
                  <p class="number-summary">{input.summary || input.importanceReason}</p>
                  <div class="number-footer">
                    <span>Used in {input.usedIn?.length || 0} scenarios</span>
                    {input.source_url && (
                      <a href={input.source_url} target="_blank" rel="noreferrer">
                        Source
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section id="calculations" class="landing-section">
      <div class="section-header">
        <p class="section-kicker">Section 2</p>
        <h2>Calculations</h2>
        <p>
          This is the interactive layer. Take the inputs above, swap comparable benchmarks, and see how
          quickly the outputs move when the assumptions change.
        </p>
      </div>

      <div class="calculator-shell">
        <NapkinApp
          client:load
          initialInputs={inputs}
          initialScenarios={scenarios}
          initialView="scenarios"
          showInputLibrary={false}
          showHeader={false}
          showAbout={false}
        />
      </div>
    </section>

    <section id="blogs" class="landing-section section-essay">
      <div class="section-header">
        <p class="section-kicker">Section 3</p>
        <h2>Blogs</h2>
        <p>
          Working notes and short essays can now live in the markdown content library alongside inputs,
          scenarios, asks, and key papers.
        </p>
      </div>

      <div class="essay-grid">
        <article class="essay-card">
          <div class="essay-header">
            <span class="mini-badge essay-status">{featuredBlog.statusLabel}</span>
            <a href="/#calculations">Open calculator</a>
          </div>
          <h3>{featuredBlog.title}</h3>
          <p>{featuredBlog.excerpt}</p>

          <div class="placeholder-metric-grid">
            <div class="placeholder-metric">
              <span>Commissioning estimate</span>
              <strong>{blogPlaceholder.commissioningCost}</strong>
            </div>
            <div class="placeholder-metric">
              <span>OpenAI annualized revenue</span>
              <strong>{blogPlaceholder.openAiRevenue}</strong>
            </div>
            <div class="placeholder-metric">
              <span>Anthropic annualized revenue</span>
              <strong>{blogPlaceholder.anthropicRevenue}</strong>
            </div>
            <div class="placeholder-metric">
              <span>Combined revenue anchor</span>
              <strong>{blogPlaceholder.combinedRevenue}</strong>
            </div>
          </div>

          <p>
            At the current defaults, the commissioning estimate is roughly
            {blogPlaceholder.multipleVsCombined ? ` ${blogPlaceholder.multipleVsCombined} ` : ' '}
            the combined OpenAI-plus-Anthropic revenue anchor. That mismatch is the core tension this
            placeholder post should unpack.
          </p>
        </article>
      </div>
    </section>

    <section id="papers" class="landing-section section-papers">
      <div class="section-header">
        <p class="section-kicker">Section 4</p>
        <h2>Highlighted papers and trackers</h2>
        <p>
          A short reading list of outside sources that do real work for the numbers on this site:
          benchmark papers, model cards, dataset cards, and live trackers that add context beyond the calculator itself.
        </p>
      </div>

      <div class="paper-grid">
        {allPaperHighlights.map((paper) => (
          <article class="paper-card">
            <div class="paper-card-top">
              <span class="mini-badge">{paper.quality ? paper.quality : 'Reference'}</span>
              {paper.links.length > 0 && (
                <div class="paper-card-links">
                  {paper.links.map((link) => (
                    <a href={link.href} target="_blank" rel="noreferrer">
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
            <h3>{paper.title}</h3>
            <p class="paper-anchor">{paper.anchor}</p>
            <p>{paper.blurb}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="watch" class="landing-section section-watch">
      <div class="section-header">
        <p class="section-kicker">Section 5</p>
        <h2>Indicators to watch and our asks</h2>
        <p>
          The calculator is only as good as the disclosures around it. This section keeps the emphasis on
          what we still need from companies, publishers, and public reporting.
        </p>
      </div>

      <div class="watch-grid">
        <article class="watch-card watch-card-indicators">
          <h3>Indicators we want to watch</h3>
          <ul>
            {watchIndicators.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="watch-card watch-card-asks">
          <h3>Our asks</h3>
          <ul>
            {ourAsks.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-shell {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .landing-hero,
  .landing-section {
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 16px 32px rgba(31, 39, 51, 0.08);
  }

  .landing-hero {
    padding: 2rem;
    background:
      radial-gradient(circle at 10% 10%, rgba(255, 255, 255, 0.82), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(247, 249, 252, 0.92)),
      rgba(255, 255, 255, 0.84);
  }

  .hero-copy {
    max-width: 820px;
  }

  .hero-copy h1 {
    margin-bottom: 0.8rem;
    color: var(--primary-color);
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.02;
  }

  .hero-text {
    max-width: 720px;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.62rem 0.98rem;
    border-radius: 999px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    color: var(--ink-soft);
    font-family: var(--font-ui);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.9);
    transition: transform 0.18s ease, background-color 0.18s ease, color 0.18s ease;
  }

  .hero-link:hover {
    transform: translateY(-1px);
    color: var(--primary-color);
  }

  .hero-link-primary {
    color: var(--white);
    background: linear-gradient(135deg, var(--primary-color), #3a618c);
  }

  .hero-link-primary:hover {
    color: var(--white);
  }

  .landing-section {
    margin-top: 1.5rem;
    padding: 1.4rem;
  }

  .input-topic-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.15rem;
  }

  .input-topic-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.52rem 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    color: var(--ink-soft);
    font-family: var(--font-ui);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.88);
    transition: transform 0.18s ease, border-color 0.18s ease, color 0.18s ease;
  }

  .input-topic-link:hover {
    transform: translateY(-1px);
    color: var(--primary-color);
    border-color: rgba(43, 76, 111, 0.2);
  }

  .input-topic-list {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .input-topic-section {
    padding: 1rem;
    border-radius: 22px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    background:
      linear-gradient(180deg, rgba(247, 249, 252, 0.58), rgba(255, 255, 255, 0.92)),
      rgba(255, 255, 255, 0.9);
  }

  .input-topic-header {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: 1rem;
    align-items: end;
    margin-bottom: 0.95rem;
  }

  .input-topic-kicker {
    margin-bottom: 0.3rem;
  }

  .input-topic-header h3 {
    margin-bottom: 0;
  }

  .input-topic-header p {
    margin-bottom: 0;
    color: var(--ink-soft);
  }

  .section-header {
    max-width: 760px;
    margin-bottom: 1.25rem;
  }

  .section-header-inline {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    max-width: none;
  }

  .section-kicker {
    margin-bottom: 0.4rem;
    color: var(--dark-gray);
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .section-header h2 {
    margin-bottom: 0.5rem;
    color: var(--black);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .section-header p {
    margin-bottom: 0;
    color: var(--ink-soft);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(216, 222, 230, 0.92);
    font-family: var(--font-ui);
    text-decoration: none;
  }

  .number-grid,
  .essay-grid,
  .paper-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .watch-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .number-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    min-height: 100%;
    padding: 1rem;
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.88);
  }

  .essay-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .essay-card {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 24px;
    background:
      linear-gradient(120deg, rgba(43, 76, 111, 0.06), rgba(255, 255, 255, 0) 44%),
      rgba(255, 255, 255, 0.94);
    box-shadow: 0 18px 34px rgba(31, 39, 51, 0.08);
  }

  .paper-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-height: 100%;
    padding: 1.1rem 1.15rem 1.2rem;
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-left: 4px solid rgba(43, 76, 111, 0.18);
