---
import NapkinApp from '../components/NapkinApp.vue';
import Layout from '../layouts/Layout.astro';
import { loadNapkinData } from '../lib/napkin-data';

const { inputs, scenarios } = await loadNapkinData();
---

<Layout
  title="Calculator - Exploring AI: Data Napkin Math"
  description="Estimate AI payouts, dataset costs, and benchmark expenses with editable public assumptions and source-backed shared inputs."
>
  <NapkinApp
    client:load
    initialInputs={inputs}
    initialScenarios={scenarios}
    showInputLibrary={false}
    pageTitle="Data Napkin Math"
    pageDescription="Four public scenarios for asking what AI revenue, training data, and new labour might cost or pay under different assumptions."
  />
</Layout>
