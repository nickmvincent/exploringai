---
import Layout from '../layouts/Layout.astro';
import { createCalculationFunction, humanReadable } from '../lib/calculations';
import { loadNapkinData } from '../lib/napkin-data';

const { inputs, scenarios, inputCount, scenarioCount } = await loadNapkinData();

function formatScenarioPreview(scenarioId: string) {
  const scenario = scenarios.find((entry) => entry.id === scenarioId);
  if (!scenario) return 'Unavailable';

  const rawValue = createCalculationFunction(scenario)(
    ...scenario.input_variables.map((inputKey) => inputs[inputKey]?.value ?? 0)
  );

  return `${humanReadable(rawValue)} ${scenario.result_units}`.trim();
}

const exampleSummaries = {
  'distributing-ai-company-revenue-broadly':
    'Start with current AI revenue and ask what it amounts to per person when spread across a large population.',
  'distributing-money-from-data-deals':
    'Use a disclosed platform deal to see what a payout looks like once it is distributed across users.',
  'producing-an-expert-evaluation-set':
    'Estimate what it would cost to pay experts for a benchmark or evaluation dataset.',
  'commissioning-new-datasets':
    'Ask what a genuinely new, LLM-scale dataset might cost if the underlying labour were paid for directly.',
} as const;

const exampleOrder = [
  'distributing-ai-company-revenue-broadly',
  'distributing-money-from-data-deals',
  'producing-an-expert-evaluation-set',
  'commissioning-new-datasets',
] as const;

type ExampleCard = {
  id: (typeof exampleOrder)[number];
  title: string;
  category: string;
  resultLabel: string;
  result: string;
  summary: string;
};

const examples = exampleOrder
  .map((id) => {
    const scenario = scenarios.find((entry) => entry.id === id);
    if (!scenario) return null;

    return {
      id,
      title: scenario.title,
      category: scenario.category,
      resultLabel: scenario.result_label,
      result: formatScenarioPreview(id),
      summary: exampleSummaries[id],
    };
  })
  .filter((example): example is ExampleCard => Boolean(example));

const homeStats = [
  `${scenarioCount} public scenarios`,
  `${inputCount} shared inputs with source notes`,
  'Share links preserve every edit',
];
---

<Layout
  title="Exploring AI: Data Napkin Math"
  description="Estimate AI payouts, dataset costs, and benchmark expenses with transparent scenarios, shared inputs, and editable public assumptions."
>
  <main id="site-main" class="home-shell">
    <section class="home-hero">
      <p class="section-kicker">Exploring AI: Data Napkin Math</p>
      <h1>Estimate payouts, dataset costs, and benchmark expenses from editable public assumptions.</h1>
      <p class="hero-copy">
        Start from a concrete public example, inspect the shared assumptions behind it, and change the
        numbers directly when you want to test a different benchmark or distribution question.
      </p>

      <div class="hero-actions">
        <a class="hero-link hero-link-primary" href="/scenarios">Open scenarios</a>
        <a class="hero-link" href="/inputs">Open inputs library</a>
      </div>

      <ul class="hero-stats list-unstyled">
        {homeStats.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="examples-section">
      <div class="section-header">
        <p class="section-kicker">Examples</p>
        <h2>Start with one of these questions</h2>
        <p>Each example opens the full scenario with the public defaults loaded, ready for edits and source inspection.</p>
      </div>

      <div class="example-grid">
        {examples.map((example) => (
          <a class="example-card" href={`/scenarios?scenario=${example.id}`}>
            <span class="example-category">{example.category}</span>
            <h3>{example.title}</h3>
            <p>{example.summary}</p>
            <div class="example-result">
              <span>{example.resultLabel}</span>
              <strong>{example.result}</strong>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="path-grid" aria-label="Full site sections">
      <article class="path-card">
        <p class="section-kicker">Full page</p>
        <h2>Scenarios</h2>
        <p>
          Work through the public examples, change the assumptions in place, and watch how each result
          moves as the shared inputs change.
        </p>
        <a class="hero-link hero-link-primary" href="/scenarios">Browse all scenarios</a>
      </article>

      <article class="path-card">
        <p class="section-kicker">Library</p>
        <h2>Inputs</h2>
        <p>
          Browse the underlying inputs directly, filter by question type or source quality, and inspect the
          citations, review notes, and scenario usage behind each number.
        </p>
        <a class="hero-link" href="/inputs">Browse inputs library</a>
      </article>
    </section>
  </main>
</Layout>

<style>
  .home-shell {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .home-hero,
  .examples-section,
  .path-card {
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 16px 32px rgba(31, 39, 51, 0.08);
  }

  .home-hero {
    padding: 2rem;
    background:
      radial-gradient(circle at 12% 10%, rgba(255, 255, 255, 0.88), transparent 36%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(247, 249, 252, 0.94)),
      rgba(255, 255, 255, 0.88);
  }

  .home-hero h1 {
    max-width: 780px;
    margin-bottom: 0.9rem;
    color: var(--primary-color);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.02;
  }

  .hero-copy,
  .section-header p,
  .example-card p,
  .path-card p {
    color: var(--ink-soft);
  }

  .hero-copy {
    max-width: 52rem;
    margin-bottom: 0;
    font-size: 1.08rem;
  }

  .hero-actions,
  .hero-stats,
  .path-grid {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .hero-actions {
    margin-top: 1.35rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.64rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    background: rgba(255, 255, 255, 0.92);
    color: var(--ink-soft);
    font-family: var(--font-ui);
    text-decoration: none;
    transition:
      transform 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease;
  }

  .hero-link:hover,
  .example-card:hover {
    transform: translateY(-1px);
  }

  .hero-link:hover {
    color: var(--primary-color);
  }

  .hero-link-primary {
    color: var(--white);
    background: linear-gradient(135deg, var(--primary-color), #3a618c);
    border-color: transparent;
  }

  .hero-link-primary:hover {
    color: var(--white);
    background: linear-gradient(135deg, var(--primary-hover), var(--primary-color));
  }

  .hero-stats {
    margin-top: 1.15rem;
  }

  .hero-stats li {
    display: inline-flex;
    align-items: center;
    min-height: 2.1rem;
    padding: 0.4rem 0.78rem;
    border-radius: 999px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    background: rgba(255, 255, 255, 0.94);
    color: var(--dark-gray);
    font-family: var(--font-ui);
    font-size: 0.92rem;
  }

  .examples-section {
    margin-top: 1.4rem;
    padding: 1.5rem;
  }

  .section-header {
    max-width: 680px;
    margin-bottom: 1.2rem;
  }

  .section-kicker {
    margin-bottom: 0.42rem;
    color: var(--dark-gray);
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .section-header h2,
  .path-card h2 {
    margin-bottom: 0.45rem;
    color: var(--black);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }

  .section-header p,
  .path-card p {
    margin-bottom: 0;
  }

  .example-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .example-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.2rem;
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.94);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 10px 22px rgba(31, 39, 51, 0.06);
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .example-card:hover {
    border-color: rgba(43, 76, 111, 0.24);
    box-shadow: 0 14px 26px rgba(31, 39, 51, 0.08);
  }

  .example-card h3 {
    margin-bottom: 0;
    color: var(--black);
    font-size: 1.22rem;
    line-height: 1.18;
  }

  .example-card p {
    margin-bottom: 0;
  }

  .example-category {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    padding: 0.24rem 0.62rem;
    border-radius: 999px;
    background: rgba(43, 76, 111, 0.08);
    color: var(--primary-color);
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .example-result {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(216, 222, 230, 0.92);
  }

  .example-result span {
    color: var(--dark-gray);
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .example-result strong {
    color: var(--primary-color);
    font-family: var(--font-heading);
    font-size: 1.24rem;
  }

  .path-grid {
    margin-top: 1.4rem;
    align-items: stretch;
  }

  .path-card {
    flex: 1 1 320px;
    padding: 1.5rem;
  }

  .path-card .hero-link {
    margin-top: 1.1rem;
  }

  @media (max-width: 760px) {
    .home-shell {
      padding: 1.5rem 1rem 3rem;
    }

    .home-hero,
    .examples-section,
    .path-card {
      border-radius: 20px;
    }

    .example-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
