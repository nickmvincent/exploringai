---
import { getCollection } from 'astro:content';
import NapkinApp from '../components/NapkinApp.vue';
import Layout from '../layouts/Layout.astro';
import type { Input, Scenario } from '../lib/calculations';
import { createCalculationFunction, formatValue, humanReadable } from '../lib/calculations';

const inputEntries = await getCollection('inputs');
const scenarioEntries = await getCollection('scenarios');

const scenarioReferences = scenarioEntries.map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  category: entry.data.category,
  inputVariables: entry.data.input_variables,
}));

const inputUsage = new Map<string, { id: string; title: string; category: string }[]>();
for (const scenario of scenarioReferences) {
  scenario.inputVariables.forEach((inputKey) => {
    const existing = inputUsage.get(inputKey) ?? [];
    existing.push({
      id: scenario.id,
      title: scenario.title,
      category: scenario.category,
    });
    inputUsage.set(inputKey, existing);
  });
}

const inputs: Record<string, Input> = {};
for (const entry of inputEntries) {
  const { data } = entry;
  inputs[data.variable_name] = {
    id: entry.id,
    title: data.title,
    value: data.value,
    default_value: data.value,
    scale: data.scale || 1,
    display_units: data.display_units,
    variable_name: data.variable_name,
    variable_type: data.variable_type,
    entity: data.entity ?? undefined,
    units: data.units,
    source_url: data.source_url ?? undefined,
    nice_name: data.title,
    summary: data.summary ?? undefined,
    importanceRank: data.importanceRank ?? undefined,
    importanceReason: data.importanceReason ?? undefined,
    sourceName: data.sourceName ?? undefined,
    sourceNote: data.sourceNote ?? undefined,
    sourceQuality: data.sourceQuality ?? undefined,
    confidence: data.confidence ?? undefined,
    lastReviewed: data.lastReviewed ?? undefined,
    featured: data.featured ?? false,
    min: data.min ?? undefined,
    max: data.max ?? undefined,
    step: data.step ?? undefined,
    comparisonImage: data.comparisonImage
      ? {
          src: data.comparisonImage.src,
          alt: data.comparisonImage.alt,
          caption: data.comparisonImage.caption ?? undefined,
          href: data.comparisonImage.href ?? undefined,
          label: data.comparisonImage.label ?? undefined,
        }
      : undefined,
    usedIn: inputUsage.get(data.variable_name) ?? [],
  };
}

const scenarios: Scenario[] = scenarioEntries.map((entry) => {
  const { data } = entry;
  return {
    id: entry.id,
    title: data.title,
    description: data.description,
    input_variables: data.input_variables,
    inputs: data.input_variables,
    calculation_type: data.calculation_type,
    operations: data.operations,
    result_label: data.result_label,
    result_units: data.result_units,
    category: data.category,
    result: {
      value: 'Loading...',
      rawValue: null,
      units: data.result_units,
    },
    showExplore: false,
    showCalcDetails: false,
  };
});

function getDecimalPlaces(step?: number) {
  if (!step || step >= 1) return 0;
  const decimalPart = String(step).split('.')[1] ?? '';
  return Math.min(decimalPart.length, 6);
}

function formatInputNumber(input: Input) {
  const displayedValue = formatValue(input.value, input.scale);
  const formatter = new Intl.NumberFormat('en-US', {
    minimumFractionDigits: 0,
    maximumFractionDigits: getDecimalPlaces(input.step),
  });

  return formatter.format(displayedValue);
}

const simpleInputIds = [
  'dataset_size__llama3__tokens',
  'dataset_size__olmo3__tokens',
  'training_detail__openai__words_per_token',
  'dataset_size__hle__questions',
  'deal_group_size__reddit__daily_active_users',
  'group_size__usa__people',
  'group_size__world__people',
  'post_training_size__tulu_3__sft_examples',
];

const simpleInputs = simpleInputIds
  .map((id) => inputs[id])
  .filter(Boolean)
  .map((input) => ({
    ...input,
    displayValue: formatInputNumber(input),
  }));

function formatMultiple(value?: number | null) {
  if (value === null || value === undefined || !Number.isFinite(value)) return null;
  if (value >= 100) return `${Math.round(value).toLocaleString('en-US')}x`;
  if (value >= 10) return `${value.toFixed(1)}x`;
  return `${value.toFixed(2)}x`;
}

const commissioningScenario = scenarios.find((scenario) => scenario.id === 'commissioning-new-datasets');
const commissioningScenarioRawValue = commissioningScenario
  ? createCalculationFunction(commissioningScenario)(
      ...commissioningScenario.input_variables.map((inputKey) => inputs[inputKey]?.value ?? 0)
    )
  : null;

const openAiRevenue = inputs['yearly_revenue__openai__dollars']?.value;
const anthropicRevenue = inputs['yearly_revenue__anthropic__dollars']?.value;
const combinedAiRevenue =
  [openAiRevenue, anthropicRevenue]
    .filter((value): value is number => typeof value === 'number' && Number.isFinite(value))
    .reduce((sum, value) => sum + value, 0) || null;

const blogPlaceholder = {
  commissioningCost:
    commissioningScenarioRawValue !== null
      ? `${humanReadable(commissioningScenarioRawValue)} ${commissioningScenario?.result_units ?? ''}`.trim()
      : 'Unavailable',
  openAiRevenue:
    openAiRevenue !== undefined
      ? `${humanReadable(openAiRevenue)} ${inputs['yearly_revenue__openai__dollars']?.units ?? ''}`.trim()
      : 'Unavailable',
  anthropicRevenue:
    anthropicRevenue !== undefined
      ? `${humanReadable(anthropicRevenue)} ${inputs['yearly_revenue__anthropic__dollars']?.units ?? ''}`.trim()
      : 'Unavailable',
  combinedRevenue:
    combinedAiRevenue !== null
      ? `${humanReadable(combinedAiRevenue)} dollars`
      : 'Unavailable',
  multipleVsCombined:
    commissioningScenarioRawValue !== null && combinedAiRevenue !== null
      ? formatMultiple(commissioningScenarioRawValue / combinedAiRevenue)
      : null,
};

const curatedPaperHighlights = [
  {
    title: 'A Sustainable AI Economy Needs Data Deals That Work for Generators',
    anchor: 'Ruoxi Jia et al., NeurIPS 2025 position paper',
    blurb:
      'Position paper and companion explorer on 73 public AI data deals, useful for grounding questions about opacity, royalties, and bargaining power in the data market.',
    quality: 'primary',
    links: [
      {
        href: 'https://neurips.cc/virtual/2025/loc/san-diego/poster/121926',
        label: 'NeurIPS poster',
      },
      {
        href: 'https://research.brickroad.network/neurips2025-data-deals',
        label: 'Data deals tracker',
      },
    ],
  },
];

const paperHighlightIds = [
  'dataset_size__hle__questions',
  'pretraining_composition__dolma_v1_6__academic_percent',
  'post_training_size__tulu_3__sft_examples',
  'dataset_size__llama3__tokens',
];

const paperHighlights = paperHighlightIds
  .map((id) => inputs[id])
  .filter(Boolean)
  .map((input) => ({
    title: input.sourceName || input.title,
    blurb: input.sourceNote || input.summary || input.importanceReason || 'Reference source highlighted in the input library.',
    anchor: input.title,
    quality: input.sourceQuality,
    links: input.source_url
      ? [
          {
            href: input.source_url,
            label: 'Read source',
          },
        ]
      : [],
  }));

const allPaperHighlights = [...curatedPaperHighlights, ...paperHighlights];

const watchIndicators = [
  'AI company earnings calls, SEC filings, and updated revenue run rates.',
  'Publisher and platform licensing deals, especially renewals with disclosed terms.',
  'Open-model releases that publish training mix, corpus size, or post-training composition.',
  'Benchmark growth and contributor-compensation norms for expert evaluation work.',
  'Inference price movement across flagship and mini model tiers.',
];

const ourAsks = [
  'Publish deal values and renewal terms in ways researchers and journalists can cite.',
  'Break out AI-specific revenue from total company revenue whenever possible.',
  'Disclose pretraining size, post-training size, and mix composition as first-class metrics.',
  'Make contributor compensation for benchmarks and labeling more legible.',
  'Treat data access, licensing, and opt-out infrastructure as measurable public-interest indicators.',
];
---

<Layout title="Data Napkin Math">
  <main class="home-shell">
    <section class="landing-hero">
      <div class="hero-copy">
        <p class="section-kicker">Interactive calculator</p>
        <h1>Napkin Math for Training Data Value</h1>
        <p class="hero-text">
          Napkin math, back-of-the-envelope estimates, and ballpark figures: this interactive page
          explores order-of-magnitude estimates for important data value questions. How will the
          proceeds and benefits of AI be distributed?
        </p>
        <div class="hero-actions">
          <a class="hero-link hero-link-primary" href="/#calculations">Open calculator</a>
          <a class="hero-link" href="/#inputs">Browse inputs</a>
          <a class="hero-link" href="https://github.com/nickmvincent/exploringai" target="_blank" rel="noreferrer">
            GitHub repository
          </a>
        </div>
      </div>

      <div class="hero-stats">
        <div class="hero-stat">
          <strong>{simpleInputs.length}</strong>
          <span>anchor inputs</span>
        </div>
        <div class="hero-stat">
          <strong>{scenarios.length}</strong>
          <span>live scenarios</span>
        </div>
        <div class="hero-stat">
          <strong>{allPaperHighlights.length}</strong>
          <span>highlighted sources</span>
        </div>
      </div>
    </section>

    <section id="inputs" class="landing-section">
      <div class="section-header">
        <p class="section-kicker">Section 1</p>
        <h2>Inputs</h2>
        <p>
          Start with plain numbers from public sources. These are the least interpretive pieces of the site:
          counts, rates, sizes, and benchmark totals that anchor the rest of the math.
        </p>
      </div>

      <div class="number-grid">
        {simpleInputs.map((input) => (
          <article class="number-card">
            <div class="number-card-top">
              <span class="mini-badge">{input.sourceQuality === 'primary' ? 'Primary' : 'Official'}</span>
              {input.lastReviewed && <span class="number-meta">Reviewed {input.lastReviewed}</span>}
            </div>
            <h3>{input.title}</h3>
            <div class="number-value">{input.displayValue}</div>
            <div class="number-units">{input.display_units}</div>
            <p class="number-summary">{input.summary || input.importanceReason}</p>
            <div class="number-footer">
              <span>Used in {input.usedIn?.length || 0} scenarios</span>
              {input.source_url && (
                <a href={input.source_url} target="_blank" rel="noreferrer">
                  Source
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="calculations" class="landing-section">
      <div class="section-header">
        <p class="section-kicker">Section 2</p>
        <h2>Calculations</h2>
        <p>
          This is the interactive layer. Take the inputs above, swap comparable benchmarks, and see how
          quickly the outputs move when the assumptions change.
        </p>
      </div>

      <div class="calculator-shell">
        <NapkinApp
          client:load
          initialInputs={inputs}
          initialScenarios={scenarios}
          initialView="scenarios"
          showInputLibrary={false}
          showHeader={false}
          showAbout={false}
        />
      </div>
    </section>

    <section id="blogs" class="landing-section">
      <div class="section-header">
        <p class="section-kicker">Section 3</p>
        <h2>Blogs</h2>
        <p>
          One placeholder lives here for now: a future post about the tension between the replacement cost
          of commissioning new data and the scale of current AI revenue.
        </p>
      </div>

      <div class="snapshot-grid snapshot-grid-single">
        <article class="snapshot-card snapshot-card-placeholder">
          <div class="snapshot-header">
            <span class="mini-badge">Placeholder</span>
            <a href="/#calculations">Open calculator</a>
          </div>
          <h3>Commissioning a new frontier dataset versus current AI revenue</h3>
          <p>
            This slot should become a walkthrough of one unresolved tension in the calculator. If we try to
            pay to commission a new LLM-scale dataset from scratch, the replacement-cost estimate becomes
            enormous very quickly, while the current public revenue anchors for frontier AI companies remain
            far smaller.
          </p>

          <div class="placeholder-metric-grid">
            <div class="placeholder-metric">
              <span>Commissioning estimate</span>
              <strong>{blogPlaceholder.commissioningCost}</strong>
            </div>
            <div class="placeholder-metric">
              <span>OpenAI annualized revenue</span>
              <strong>{blogPlaceholder.openAiRevenue}</strong>
            </div>
            <div class="placeholder-metric">
              <span>Anthropic annualized revenue</span>
              <strong>{blogPlaceholder.anthropicRevenue}</strong>
            </div>
            <div class="placeholder-metric">
              <span>Combined revenue anchor</span>
              <strong>{blogPlaceholder.combinedRevenue}</strong>
            </div>
          </div>

          <p>
            At the current defaults, the commissioning estimate is roughly
            {blogPlaceholder.multipleVsCombined ? ` ${blogPlaceholder.multipleVsCombined} ` : ' '}
            the combined OpenAI-plus-Anthropic revenue anchor. That mismatch is the core tension this
            placeholder post should unpack.
          </p>
        </article>
      </div>
    </section>

    <section id="papers" class="landing-section">
      <div class="section-header">
        <p class="section-kicker">Section 4</p>
        <h2>Highlighted papers and trackers</h2>
        <p>
          A short reading list of outside sources that do real work for the numbers on this site:
          benchmark papers, model cards, dataset cards, and live trackers that add context beyond the calculator itself.
        </p>
      </div>

      <div class="paper-grid">
        {allPaperHighlights.map((paper) => (
          <article class="paper-card">
            <div class="paper-card-top">
              <span class="mini-badge">{paper.quality ? paper.quality : 'Reference'}</span>
              {paper.links.length > 0 && (
                <div class="paper-card-links">
                  {paper.links.map((link) => (
                    <a href={link.href} target="_blank" rel="noreferrer">
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
            <h3>{paper.title}</h3>
            <p class="paper-anchor">{paper.anchor}</p>
            <p>{paper.blurb}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="watch" class="landing-section">
      <div class="section-header">
        <p class="section-kicker">Section 5</p>
        <h2>Indicators to watch and our asks</h2>
        <p>
          The calculator is only as good as the disclosures around it. This section keeps the emphasis on
          what we still need from companies, publishers, and public reporting.
        </p>
      </div>

      <div class="watch-grid">
        <article class="watch-card">
          <h3>Indicators we want to watch</h3>
          <ul>
            {watchIndicators.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="watch-card">
          <h3>Our asks</h3>
          <ul>
            {ourAsks.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-shell {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .landing-hero,
  .landing-section {
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 16px 32px rgba(31, 39, 51, 0.08);
  }

  .landing-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.8fr);
    gap: 1.5rem;
    padding: 2rem;
    background:
      radial-gradient(circle at 10% 10%, rgba(255, 255, 255, 0.82), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(247, 249, 252, 0.92)),
      rgba(255, 255, 255, 0.84);
  }

  .hero-copy h1 {
    margin-bottom: 0.8rem;
    color: var(--primary-color);
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.02;
  }

  .hero-text {
    max-width: 720px;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.62rem 0.98rem;
    border-radius: 999px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    color: var(--ink-soft);
    font-family: var(--font-ui);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.9);
    transition: transform 0.18s ease, background-color 0.18s ease, color 0.18s ease;
  }

  .hero-link:hover {
    transform: translateY(-1px);
    color: var(--primary-color);
  }

  .hero-link-primary {
    color: var(--white);
    background: linear-gradient(135deg, var(--primary-color), #3a618c);
  }

  .hero-link-primary:hover {
    color: var(--white);
  }

  .hero-stats {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .hero-stat {
    padding: 1rem 1.1rem;
    border-radius: 20px;
    border: 1px solid rgba(216, 222, 230, 0.92);
    background: rgba(255, 255, 255, 0.9);
  }

  .hero-stat strong {
    display: block;
    color: var(--primary-color);
    font-family: var(--font-heading);
    font-size: 2rem;
    line-height: 1;
  }

  .hero-stat span {
    color: var(--dark-gray);
    font-size: 0.92rem;
  }

  .landing-section {
    margin-top: 1.5rem;
    padding: 1.4rem;
  }

  .section-header {
    max-width: 760px;
    margin-bottom: 1.25rem;
  }

  .section-header-inline {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    max-width: none;
  }

  .section-kicker {
    margin-bottom: 0.4rem;
    color: var(--dark-gray);
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .section-header h2 {
    margin-bottom: 0.5rem;
    color: var(--black);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .section-header p {
    margin-bottom: 0;
    color: var(--ink-soft);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(216, 222, 230, 0.92);
    font-family: var(--font-ui);
    text-decoration: none;
  }

  .number-grid,
  .snapshot-grid,
  .paper-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .snapshot-grid-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .watch-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .number-card,
  .snapshot-card,
  .paper-card,
  .watch-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    min-height: 100%;
    padding: 1rem;
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.88);
  }

  .snapshot-card-placeholder {
    gap: 1rem;
  }

  .number-card-top,
  .snapshot-header,
  .paper-card-top,
  .number-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .mini-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.24rem 0.56rem;
    border-radius: 999px;
    color: var(--primary-color);
    background: rgba(43, 76, 111, 0.08);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    text-transform: capitalize;
  }

  .number-meta,
  .number-footer,
  .snapshot-result-label,
  .snapshot-result-units,
  .paper-anchor {
    color: var(--dark-gray);
    font-size: 0.9rem;
  }

  .number-card h3,
  .snapshot-card h3,
  .paper-card h3,
  .watch-card h3 {
    margin-bottom: 0;
  }

  .number-value,
  .snapshot-result-value {
    color: var(--primary-color);
    font-family: var(--font-heading);
    font-size: 2rem;
    line-height: 1;
  }

  .number-summary,
  .snapshot-card p,
  .paper-card p,
  .watch-card li {
    color: var(--ink-soft);
  }

  .number-footer a,
  .snapshot-header a,
  .paper-card-top a {
    color: var(--primary-color);
    text-decoration: none;
  }

  .number-footer a:hover,
  .snapshot-header a:hover,
  .paper-card-top a:hover {
    text-decoration: underline;
  }

  .paper-card-links {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .placeholder-metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem;
  }

  .placeholder-metric {
    padding: 0.9rem 1rem;
    border: 1px solid rgba(216, 222, 230, 0.92);
    border-radius: 16px;
    background: rgba(247, 249, 252, 0.72);
  }

  .placeholder-metric span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--dark-gray);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .placeholder-metric strong {
    color: var(--primary-color);
    font-family: var(--font-heading);
    font-size: 1.3rem;
    line-height: 1.15;
  }

  .calculator-shell {
    border-radius: 20px;
    overflow: hidden;
  }

  .watch-card ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .watch-card li + li {
    margin-top: 0.6rem;
  }

  #inputs,
  #calculations,
  #blogs,
  #papers,
  #watch {
    scroll-margin-top: calc(var(--navbar-height) + 1rem);
  }

  @media (max-width: 920px) {
    .landing-hero {
      grid-template-columns: 1fr;
    }

    .section-header-inline,
    .watch-grid {
      grid-template-columns: 1fr;
      display: grid;
    }
  }

  @media (max-width: 640px) {
    .home-shell {
      padding: 1.5rem 1rem 3rem;
    }

    .landing-hero,
    .landing-section {
      border-radius: 22px;
      padding: 1.2rem;
    }

    .hero-actions,
    .number-grid,
    .snapshot-grid,
    .paper-grid,
    .watch-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
