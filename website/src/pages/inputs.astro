---
import NapkinApp from '../components/NapkinApp.vue';
import Layout from '../layouts/Layout.astro';
import { loadNapkinData } from '../lib/napkin-data';

const { inputs, scenarios } = await loadNapkinData();
---

<Layout
  title="Inputs Library - Exploring AI: Data Napkin Math"
  description="Inspect the shared assumptions behind every AI napkin-math scenario, including source quality, citations, review notes, and downstream usage."
>
  <NapkinApp
    client:load
    initialInputs={inputs}
    initialScenarios={scenarios}
    initialView="inputs"
    showScenarioLibrary={false}
    showAbout={false}
    pageTitle="Inputs Library"
    pageDescription="Browse and edit the shared inputs behind every scenario."
  />
</Layout>
