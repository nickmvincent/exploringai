---
const targetPath = '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to Calculator</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={targetPath} />
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
    <script is:inline>
      const target = new URL('/', window.location.origin);
      target.search = window.location.search;
      target.hash = window.location.hash;
      window.location.replace(target.toString());
    </script>
    <style>
      :root {
        color-scheme: light;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        color: #1f2733;
        background: #fbfaf7;
        font-family: 'Source Sans 3', system-ui, sans-serif;
      }

      main {
        max-width: 36rem;
        padding: 1.5rem;
        border: 1px solid #d8dee6;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 16px 32px rgba(31, 39, 51, 0.08);
      }

      h1 {
        margin: 0 0 0.65rem;
        font-size: 1.8rem;
        line-height: 1.1;
      }

      p {
        margin: 0;
        line-height: 1.6;
      }

      a {
        color: #2b4c6f;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Redirecting to Calculator</h1>
      <p>
        The main calculator now lives on the home page.
        <a href={targetPath}>Continue to the calculator</a>.
      </p>
    </main>
  </body>
</html>
