---
import Layout from '../layouts/Layout.astro';
import NetworkDiscussions from '../../../helpers/astro/NetworkDiscussions.astro';
import type { NetworkData } from '../../../helpers/network-data';

// Use static import - Vite can resolve this at build time
import networkData from '../data/network.json';
---

<Layout title="Discussions & Network - Data Napkin Math">
  <NetworkDiscussions
    networkData={networkData as NetworkData}
    backLinkHref="/"
    backLinkLabel="← Back to home"
    hideProjectLinks={true}
    hideRelatedProjects={true}
    classes={{
      container: 'container',
      header: 'page-header',
      subtitle: 'subtitle',
      backLink: 'btn',
      section: 'section',
      discussionsList: 'link-list',
      list: 'link-list',
      description: 'description',
      muted: 'muted',
    }}
  />
</Layout>

<style>
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
    padding: 1.75rem;
    border: 1px solid rgba(179, 90, 30, 0.18);
    border-radius: 24px;
    background: rgba(255, 250, 242, 0.9);
    box-shadow: 0 12px 24px rgba(78, 56, 36, 0.12);
  }

  .page-header h1 {
    margin-bottom: 0.5rem;
    color: var(--primary-color);
  }

  .subtitle {
    color: var(--dark-gray);
    margin-bottom: 1rem;
  }

  .btn {
    display: inline-block;
    padding: 0.58rem 0.95rem;
    background: linear-gradient(135deg, var(--primary-color), #c56e31);
    color: var(--white);
    text-decoration: none;
    border-radius: 999px;
    box-shadow: 0 8px 18px rgba(179, 90, 30, 0.18);
  }

  .btn:hover {
    background: linear-gradient(135deg, var(--primary-hover), var(--primary-color));
  }

  .section {
    background: rgba(255, 250, 242, 0.92);
    border-radius: 24px;
    border: 1px solid rgba(179, 90, 30, 0.18);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 12px 24px rgba(78, 56, 36, 0.1);
  }

  .section h2 {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-list li {
    margin-bottom: 0.5rem;
  }

  .link-list a {
    color: var(--primary-color);
    text-decoration: none;
  }

  .link-list a:hover {
    text-decoration: underline;
  }

  .muted {
    color: var(--dark-gray);
    font-size: 0.875rem;
  }

  .description {
    display: block;
    color: var(--dark-gray);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .container {
      padding: 1.5rem 1rem 2.5rem;
    }

    .page-header,
    .section {
      border-radius: 20px;
    }
  }
</style>
