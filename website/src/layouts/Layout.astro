---
import NetworkFooter from '../../../helpers/astro/NetworkFooter.astro';
import networkData from '../data/network.json';

interface Props {
  title: string;
}

const { title } = Astro.props;
const networkLinks = networkData.allProjects.map(p => ({ href: p.website, label: p.title }));
const allowIndexing = import.meta.env.PUBLIC_ALLOW_INDEXING !== 'false';
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Interactive napkin math for AI training-data value, compensation benchmarks, and distribution scenarios."
    />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {!allowIndexing && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="navbar">
      <a class="navbar-brand" href="/">Data Napkin Math</a>
      <ul class="navbar-nav">
        <li><a class="nav-link" href="/#inputs">Inputs</a></li>
        <li><a class="nav-link" href="/#calculations">Calculations</a></li>
        <li><a class="nav-link" href="/#blogs">Blogs</a></li>
        <li><a class="nav-link" href="/#papers">Papers</a></li>
        <li><a class="nav-link" href="/#watch">Watch</a></li>
        <li><a class="nav-link" href="https://github.com/nickmvincent/exploringai" target="_blank" rel="noreferrer">GitHub</a></li>
      </ul>
    </nav>
    <slot />
    <NetworkFooter links={networkLinks} />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .network-footer {
    margin-top: 3rem;
    padding: 1.6rem 1.2rem 2.2rem;
    border-top: 1px solid var(--border-color);
    background: var(--paper);
    text-align: center;
    font-size: 0.875rem;
  }
  .network-footer-content {
    max-width: 800px;
    margin: 0 auto;
  }
  .network-label {
    color: var(--dark-gray);
    margin-right: 0.5rem;
  }
  .network-links {
    display: inline;
  }
  .network-links a {
    color: var(--primary-color);
    text-decoration: none;
    margin: 0 0.5rem;
  }
  .network-links a:hover {
    text-decoration: underline;
  }
</style>
