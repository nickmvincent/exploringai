---
interface Props {
  title: string;
}

const { title } = Astro.props;
const allowIndexing = import.meta.env.PUBLIC_ALLOW_INDEXING !== 'false';
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : null;
const currentPath = Astro.url.pathname;

const navLinks = [
  {
    href: '/',
    label: 'Home',
    isActive: currentPath === '/',
  },
  {
    href: '/calculator',
    label: 'Calculator',
    isActive: currentPath === '/calculator',
  },
  {
    href: '/calculator?view=inputs',
    label: 'Inputs',
    isActive: false,
  },
  {
    href: '/#resources',
    label: 'Resources',
    isActive: false,
  },
  {
    href: '/discussions',
    label: 'Discussions',
    isActive: currentPath === '/discussions',
  },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Interactive napkin math for AI training-data value, compensation benchmarks, and distribution scenarios."
    />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {!allowIndexing && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="navbar">
      <a class="navbar-brand" href="/">Exploring AI: Data Napkin Math</a>
      <ul class="navbar-nav">
        {navLinks.map((link) => (
          <li>
            <a class:list={['nav-link', link.isActive && 'nav-link-active']} href={link.href}>
              {link.label}
            </a>
          </li>
        ))}
        <li><a class="nav-link" href="https://github.com/nickmvincent/exploringai" target="_blank" rel="noreferrer">GitHub</a></li>
      </ul>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
